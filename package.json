{
  "name": "gimnasio-menu-app",
  "version": "0.1.0",
  "description": "App para gestionar recetas y validarlas contra el menú semanal",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test --test-reporter=spec tests/unit/*.test.js",
    "test:integration": "node --test --test-reporter=spec tests/integration/*.test.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "supertest": "^7.2.2"
  }
}
